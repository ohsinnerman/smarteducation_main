# .env.example — the single source of truth for configuration.
# Copy to `.env` (kept out of git) and fill in. Every variable below is actually
# read by the code; nothing here is decorative. Run `python manage.py diagnose_env`
# to see what resolved.
#
# Loading: settings pin decouple to <repo root>/.env explicitly, so it loads the
# same way regardless of the working directory (local, Docker WORKDIR, systemd).

# ── Django core ───────────────────────────────────────────────────────────────
# development | production. Selects the settings module and, in production,
# turns the required-var checks below into hard startup failures.
DJANGO_ENV=development

# Cryptographic signing key. REQUIRED in production (startup fails without it).
# Dev falls back to an insecure built-in default. Generate: `python -c
# "import secrets; print(secrets.token_urlsafe(50))"`
DJANGO_SECRET_KEY=your-secret-key-here

# True enables debug pages/tracebacks. Never True in production. Default: True in
# dev, forced False in production.
DJANGO_DEBUG=True

# Comma-separated hostnames Django will serve. REQUIRED in production.
# If missing on a real server, every request returns HTTP 400.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Single source of truth for the DB. Unset ⇒ local SQLite (dev only). REQUIRED in
# production — a missing DATABASE_URL there is a hard failure (no silent SQLite).
# Example: postgres://user:password@localhost:5432/smarteducation
# DATABASE_URL=

# ── CORS / frontend origins ───────────────────────────────────────────────────
# Comma-separated origins allowed to call the API cross-origin (the separately
# hosted frontend). REQUIRED in production. Never "*".
# Example: https://app.example.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Origins trusted for CSRF (needed if the browser posts forms cross-origin).
# CSRF_TRUSTED_ORIGINS=https://app.example.com

# ── JWT lifetimes (optional; sensible defaults) ───────────────────────────────
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# ── Email (SMTP) — optional; leave blank to DISABLE email notifications ────────
# Both USER and PASSWORD must be set for email to work. If blank, senders log a
# warning and record the notification as failed (they do not crash).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True

# ── Twilio (SMS & WhatsApp) — optional; leave blank to DISABLE SMS/WhatsApp ────
# All three must be set. If blank, SMS/WhatsApp senders log a warning and no-op.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OpenAI — optional; leave blank to use canned insight text ─────────────────
# (Currently ml/genai.py only has the fallback path; this key wires future
# OpenAI-backed insights.)
OPENAI_API_KEY=

# ── Celery / Redis — optional in dev ──────────────────────────────────────────
# REDIS_URL is the default for both broker and result backend. Override either
# individually if they differ. In Docker this points at the `redis` service.
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# ── Demo data ─────────────────────────────────────────────────────────────────
# When True, `migrate` auto-creates the demo login accounts (admin_demo etc.).
# Leave False in any environment with real users. (Wired in Phase 2.)
SEED_DEMO_ACCOUNTS_ON_MIGRATE=False

# ── AWS / S3 (only if you enable django-storages media offload) ───────────────
# Prefer an EC2 instance role over long-lived keys. Read only when S3 storage is
# explicitly configured (not wired by default in Phase 1).
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
