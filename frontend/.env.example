# The ONLY required frontend config: the backend API base URL.
#
# LOCAL dev: point straight at the Django dev server.
VITE_API_BASE_URL=http://localhost:8000/api
#
# VERCEL (with the vercel.json rewrite proxying /api to your HTTP EC2 backend):
# use a RELATIVE path so the browser calls the same HTTPS origin and Vercel
# forwards it server-side (avoids the HTTPS-page-calling-HTTP mixed-content block):
#   VITE_API_BASE_URL=/api
#
# Never hardcode the backend URL in source — it only ever comes from here.
